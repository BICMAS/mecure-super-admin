# Copy to .env.local for local development (Vite loads VITE_* at build/dev time).

# Local backend (default in dev if unset: http://localhost:5000/api/v1)
VITE_API_BASE_URL=http://localhost:5000/api/v1

# Optional — Gemini AI features on the dashboard (tags, health insights)
# VITE_GEMINI_API_KEY=

# Production (Vercel) — host only is OK; /api/v1 is appended automatically if missing:
# VITE_API_BASE_URL=https://prime-impact-backend-production.up.railway.app
# Or include the full path explicitly:
# VITE_API_BASE_URL=https://prime-impact-backend-production.up.railway.app/api/v1
